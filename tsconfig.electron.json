{
  "compilerOptions": {
    "target":     "ES2020",
    "module":     "CommonJS",
    "lib":        ["ES2020"],
    "outDir":     "./dist/electron",
    "rootDir":    "./electron",
    "strict":     true,
    "esModuleInterop":        true,
    "resolveJsonModule":      true,
    "skipLibCheck":           true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
