# desktop-client/.env.example
# Copy to .env and fill in values.
# All variables must be prefixed with VITE_ to be accessible in the renderer.

# FastAPI backend REST base URL (no trailing slash)
VITE_BACKEND_URL=http://127.0.0.1:8000

# FastAPI backend WebSocket base URL (ws:// for local, wss:// for production)
VITE_BACKEND_WS_URL=ws://127.0.0.1:8000
